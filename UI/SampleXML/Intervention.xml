<ClinicalDocument xmlns="urn:hl7-org:v3" xmlns:sdtc="urn:hl7-org:sdtc" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xhtml="http://www.w3.org/1999/xhtml" xsi:schemaLocation="urn:hl7-org:v3 http://xreg2.nist.gov:8080/hitspValidation/schema/cdar2c32/infrastructure/cda/C32_CDA.xsd">
	<entry>
		<!--
			An Intervention Act is wrapper to identify activities as interventions. Interventions are actions taken to increase the 
			likelihood of achieving the patient's or providers' goals. 
			An Intervention Act should contain a reference to a Goal Observation representing the reason for the intervention.
			-->
		<act classCode="ACT" moodCode="INT">
			<templateId root="2.16.840.1.113883.10.20.22.4.146" extension="2015-08-01"/>
			<templateId root="2.16.840.1.113883.10.20.22.4.146"/>
			<id root="45a8d282-2409-450f-b26f-cc0eb6204296"/>
			<code code="362956003" displayName="Procedure / intervention (navigational concept)" codeSystem="2.16.840.1.113883.6.96" codeSystemName="SNOMED CT"/>
			<statusCode code="active"/>
			<effectiveTime value="{CurrentDate}"/>
			<author typeCode="AUT">
				<templateId root="2.16.840.1.113883.10.20.22.4.119"/>
				<time value="{CurrentDate}"/>
				<assignedAuthor>
					<!-- This id points back to a participant in the header -->
					<id root="d839038b-7171-4165-a760-467925b43857"/>
					<code code="{TaxonomicalCode}" codeSystem="2.16.840.1.113883.6.101" codeSystemName="Healthcare Provider Taxonomy (HIPAA)" displayName="{TaxonomicalDescription}"/>
				</assignedAuthor>
			</author>
			<entryRelationship typeCode="REFR">
				<act classCode="ACT" moodCode="INT">
					<templateId root="2.16.840.1.113883.10.20.22.4.39" extension="2014-06-09"/>
					<templateId root="2.16.840.1.113883.10.20.22.4.39"/>
					<id root="2.16.840.1.113883.3.5811.6" extension="130C7294-F03C-4210-A76B-3B15543C5D3A" />
					<!-- Planned Act SHOULD be selected from LOINC (CodeSystem: 2.16.840.1.113883.6.1) OR SNOMED CT (CodeSystem: 2.16.840.1.113883.6.96)
						(CONF:1098-32030) -->
					{EntryTextHere}
					<statusCode code="active"/>
					<effectiveTime value="{CurrentDate}"/>
					<author typeCode="AUT">
						<templateId root="2.16.840.1.113883.10.20.22.4.119"/>
						<time value="{CurrentDate}"/>
						<assignedAuthor>
							<!-- This id points back to a participant in the header -->
							<id root="d839038b-7171-4165-a760-467925b43857"/>
							<code code="{TaxonomicalCode}" codeSystem="2.16.840.1.113883.6.101" codeSystemName="Healthcare Provider Taxonomy (HIPAA)" displayName="{TaxonomicalDescription}"/>
						</assignedAuthor>
					</author>
				</act>
			</entryRelationship>
			<entryRelationship typeCode="RSON">
				<!-- Entry Reference template -->
				<act classCode="ACT" moodCode="EVN">
					<templateId root="2.16.840.1.113883.10.20.22.4.122" />
					<!-- This id points back to an already defined Intervention in the Interventions Section -->
					<id root="b3c091b3-f9a4-41e4-a8e4-2d1b11f2eb22" />
					<code nullFlavor="NP" />
					<statusCode code="completed" />
				</act>
			</entryRelationship>
		</act>
	</entry>
</ClinicalDocument>
