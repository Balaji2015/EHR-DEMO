
<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="C5PO.Master.cs" Inherits="Acurus.Capella.UI.C5PO" %>

<%@ Register Assembly="Telerik.Web.UI" Namespace="Telerik.Web.UI" TagPrefix="telerik" %>
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <title>CAPELLA 5.0</title>

    <meta name="viewport" content="width=device-width,
         initial-scale=1" />
    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>

    <style type="text/css">
        .container {
            justify-content: left;
            text-align: left;
        }

        .fontStyle {
            font-family: Arial;
            font-weight: bold;
        }

        .LeftAlignUserName {
            margin-left: 100px;
        }

        .LeftAlignTooltip {
            margin-left: 500px;
        }

        .displayNone {
            display: none;
        }

        .SmallFont {
            font-size: small !important;
            font-family: Microsoft Sans Serif !important;
        }

        .RightAlighButton {
            position: absolute !important;
            right: 0px;
            top: 1px;
        }

        .RadToolBar {
            background-color: white;
        }

        nav {
            /*background-color: #236B8E;*/
            border: 1px solid #dedede;
            border-radius: 4px;
            box-shadow: 0 2px 2px -1px rgba(0, 0, 0, 0.055);
            color: #fff;
            display: block;
            overflow: hidden;
            width: 100%;
        }
            /*margin: 8px 22px 8px 22px;*/
            /*position:fixed;*/

            nav ul {
                margin: 0;
                padding: 0;
            }
                /**/
                nav ul li {
                    display: inline-block;
                    list-style-type: none;
                    -webkit-transition: all 0.2s;
                    -moz-transition: all 0.2s;
                    -ms-transition: all 0.2s;
                    -o-transition: all 0.2s;
                    transition: all 0.2s;
                }

            nav > ul > li > a > .caret,
            nav > ul > li > div ul > li > a > .caret, nav > ul > li > div ul > li > div ul > li > a > .caret {
                border-top: 4px solid #aaa;
                border-right: 4px solid transparent;
                border-left: 4px solid transparent;
                content: "";
                display: inline-block;
                height: 0;
                width: 0;
                vertical-align: middle;
                -webkit-transition: color 0.1s linear;
                -moz-transition: color 0.1s linear;
                -o-transition: color 0.1s linear;
                transition: color 0.1s linear;
            }

            nav > ul > li > div ul > li > a > .caret {
                border-bottom: 4px solid transparent;
                border-top: 4px solid transparent;
                border-right: 4px solid transparent;
                border-left: 4px solid #f2f2f2;
                margin: 0 0 0 8px;
            }

            nav > ul > li > div ul > li > div ul > li > a > .caret {
                border-bottom: 4px solid transparent;
                border-top: 4px solid transparent;
                border-right: 4px solid transparent;
                border-left: 4px solid #f2f2f2;
                margin: 0 0 0 8px;
            }

            nav > ul > li > a, nav > ul > li > span {
                color: #ffffff;
                display: block;
                line-height: 34px;
                padding: 0 8px;
                text-decoration: none;
            }

            nav > ul > li:hover {
                /*background-color: rgb( 40, 44, 47 ); test*/
                /*background-color: #4f94cd;*/
            }

                nav > ul > li:hover > a {
                    color: rgb( 255, 255, 255 );
                }

                    nav > ul > li:hover > a > .caret {
                        border-top-color: rgb( 255, 255, 255 );
                    }

            nav > ul > li > div ul > li:hover > a > .caret {
                border-left-color: rgb(255,255,255);
            }

            nav > ul > li > div ul > li > div ul > li:hover > a > .caret {
                border-left-color: rgb(255,255,255);
            }
            /*background-color: rgb( 40, 44, 47 );test*/
            nav > ul > li > div,
            nav > ul > li > div ul > li > div, nav > ul > li > div ul > li > div ul > li > div {
                /*background-color: #4f94cd;*/
                border-top: 0;
                border-radius: 0 0 4px 4px;
                box-shadow: 0 2px 2px -1px rgba(0, 0, 0, 0.055);
                display: none;
                margin: 0;
                opacity: 0;
                position: absolute;
                width: 165px;
                visibility: hidden;
                -webkit-transiton: opacity 0.2s;
                -moz-transition: opacity 0.2s;
                -ms-transition: opacity 0.2s;
                -o-transition: opacity 0.2s;
                -transition: opacity 0.2s;
                z-index: 999;
            }

                nav > ul > li > div ul > li > div {
                    /*background-color: rgb( 40, 44, 47 );test*/
                    /*background-color: #4f94cd;*/
                    border-radius: 0 4px 4px 4px;
                    box-shadow: inset 2px 0 5px rgba(0,0,0,.15);
                    margin-top: -42px;
                    right: -165px;
                }

                    nav > ul > li > div ul > li > div ul > li > div {
                        /*background-color: rgb( 40, 44, 47 );test*/
                        background-color: #4f94cd;
                        border-radius: 0 4px 4px 4px;
                        box-shadow: inset 2px 0 5px rgba(0,0,0,.15);
                        margin-top: -42px;
                        right: -165px;
                    }

                nav > ul > li:hover > div,
                nav > ul > li > div ul > li:hover > div {
                    display: block;
                    opacity: 1;
                    visibility: visible;
                }

                nav > ul > li > div ul > li,
                nav > ul > li > div ul > li > div ul > li {
                    display: block;
                    position: relative;
                }

                    nav > ul > li > div ul > li > a,
                    nav > ul > li > div ul > li > div ul > li > a {
                        color: #fff;
                        display: block;
                        padding: 12px 24px;
                        text-decoration: none;
                    }

                    nav > ul > li > div ul > li:hover > a,
                    nav > ul > li > div ul > li > div ul > li:hover > a {
                        background-color: rgba( 255, 255, 255, 0.1);
                    }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background-color: #c3bfbf;
        }

        ::-webkit-scrollbar-thumb {
            background-color: #707070;
        }

            ::-webkit-scrollbar-thumb:hover {
                background-color: #3d3c3a;
            }

        .menubackgroud {
            background-color: red;
        }

        .ui-dialog-titlebar-close {
            display: none;
        }

        .ui-widget {
            font-family: Verdana,Arial,sans-serif !important;
        }

        .ui-dialog {
            z-index: 5000 !important;
        }

            .ui-dialog .ui-dialog-buttonpane .ui-dialog-buttonset {
                float: none !important;
                margin-left: 45px !important;
            }

            .ui-dialog .ui-dialog-buttonpane button {
                width: 60px !important;
            }

            .ui-dialog .ui-dialog-titlebar {
                padding: 0px !important;
            }

            .ui-dialog .ui-dialog-title {
                font-size: 12px !important;
                font-family: Verdana,Arial,sans-serif !important;
            }

            .ui-dialog ui-widget ui-widget-content ui-corner-all ui-front ui-dialog-buttons ui-draggable ui-resizable {
                height: 155px;
                border: 2px solid;
                border-radius: 13px;
                top: 504px !important;
                left: 568px !important;
            }

            .ui-dialog .ui-dialog-content {
                min-height: 0px !important;
            }

            .ui-dialog .ui-dialog-buttonpane {
                margin-top: -10px !important;
                /*padding: 0px !important ;*/
            }

        .ui-widget-content {
            border: 0px !important;
        }

        .ui-widget-header, .ui-state-default, ui-button {
            font-weight: bold !important;
            font-size: 12px !important;
            font-family: sans-serif;
        }


        .ui-widget {
            border: 1px solid #adadad !important;
            background-color: #F7F7F7;
        }

        .modal-body {
            padding: 17px !important;
        }


        .spinmodal {
            position: absolute;
            top: 0;
            left: 0;
            background-color: #000000;
            z-index: 99;
            opacity: 0.7;
            height: 100%;
            width: 100%;
        }

        .disabledMenu:hover, .disabledMenu:focus {
            cursor: default !important;
            text-decoration: none !important;
            color: white !important;
        }

        .PFSHWindow {
            margin-top: 75px !important;
        }

        #ancFile:focus, #ancApptmt:focus, #ancEMR:focus, #ancPatient:focus, #ancExchange:focus,
        #ancAdmin:focus, #ancUtil:focus, #ancReports:focus, #ancWindow:focus, #ancHelp:focus {
            color: #ffffff !important;
            text-decoration: none;
        }

        @media (min-height: 800px) {
            .ProcessModal {
                height: 716px;
            }

            .ProcessModalCnt {
                height: 660px;
            }

            .mdlChart {
                height: 780px;
            }

            .mdlChartFrame {
                height: 780px;
            }

            #divCPTBody {
                height: 634px;
            }

            #divBody {
                height: 634px;
            }

            #divDiagnosisBody {
                height: 622px;
                overflow-y: auto;
                overflow-x: hidden;
            }
        }

        @media (min-height: 670px) and (max-height: 799px) {
            .ProcessModal {
                height: 616px;
            }

            .ProcessModalCnt {
                height: 540px;
            }

            .mdlChart {
                height: 655px;
            }

            .mdlChartFrame {
                height: 565px;
            }

            #divCPTBody {
                height: 514px;
            }

            #divBody {
                height: 514px;
            }
        }

        @media (max-height: 669px) {
            .ProcessModal {
                height: 516px;
            }

            .ProcessModalCnt {
                height: 440px;
            }

            .mdlChart {
                height: 530px;
            }

            .mdlChartFrame {
                height: 450px;
            }

            #divCPTBody {
                height: 400px;
            }

            #divBody {
                height: 400px;
            }

            #divDiagnosisBody {
                height: 425px;
                overflow-y: auto;
                overflow-x: hidden;
            }
        }

        #MeasureInfo {
            display: none; /* Hidden by default */
            position: fixed; /* Stay in place */
            z-index: 3030 !important; /* Sit on top */
            opacity: 1.8 !important;
            left: 0;
            top: 0;
            width: 100%; /* Full width */
            height: 100%; /* Full height */
            overflow: auto; /* Enable scroll if needed */
            background-color: rgb(0,0,0); /* Fallback color */
            background-color: rgba(0,0,0,0.4); /* Black w/ opacity */
        }

        /* Modal Content/Box */
        #modalContent {
            background-color: #fefefe;
            margin: 15% auto; /* 15% from the top and centered */
            padding: 20px;
            border: 1px solid #888;
            width: 78%; /* Could be more or less, depending on screen size */
        }

        /* The Close Button */
        #btnMeasureClose {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
        }

            #btnMeasureClose:hover,
            #btnMeasureClose:focus {
                color: black;
                text-decoration: none;
                cursor: pointer;
            }

        #modalBody {
            line-height: 23.4px;
            height: 475px;
            overflow: hidden;
        }


        #AlertInfo {
            display: none; /* Hidden by default */
            position: fixed; /* Stay in place */
            z-index: 3030 !important; /* Sit on top */
            opacity: 1.8 !important;
            left: 0;
            top: 0;
            width: 100%; /* Full width */
            height: 100%; /* Full height */
            overflow: auto; /* Enable scroll if needed */
            background-color: rgb(0,0,0); /* Fallback color */
            background-color: rgba(0,0,0,0.4); /* Black w/ opacity */
        }
        /* Modal Content/Box */
        #AlertContent {
            background-color: #fefefe;
            margin: 15% auto; /* 15% from the top and centered */
            padding: 20px;
            border: 1px solid #888;
            width: 85%; /* Could be more or less, depending on screen size */
        }

        /* The Close Button */
        #btnAlertClose {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
        }

            #btnAlertClose:hover,
            #btnAlertClose:focus {
                color: black;
                text-decoration: none;
                cursor: pointer;
            }

        #AlertBody {
            line-height: 23.4px;
            height: 100%;
            overflow: hidden;
        }

        #divNotifyPullUp {
            background-color: #e41d1d;
            color: white;
            width: 52px;
            height: 52px;
            right: 26px;
            bottom: 85px;
            position: fixed;
            opacity: 0.9;
            margin-right: 1px;
            border-radius: 60px;
            text-align: -webkit-center;
        }

            #divNotifyPullUp:hover {
                cursor: pointer;
            }

        .dvxmlalert {
            display: none;
            background: #fdfeff !important;
            box-shadow: 0 0 10px rgba(0,0,0,0.4) !important;
            box-sizing: border-box !important;
            color: #101010 !important;
            left: 50% !important;
            min-width: 645px !important;
            max-width: 700px !important;
            padding: 1.875em !important;
            position: absolute !important;
            top: 7% !important;
            transform: translate(-50%, -50%) !important;
            z-index: 2000000000 !important;
            border-radius: 10px !important;
            opacity: 0.8 !important;
        }

        #CheckAlert {
            display: none;
            background: #fdfeff;
            box-shadow: 0 0 10px rgba(0,0,0,0.4);
            box-sizing: border-box;
            color: #101010;
            left: 50%;
            min-width: 645px;
            max-width: 700px;
            padding: 1.875em;
            position: absolute;
            top: 7%;
            transform: translate(-50%, -50%);
            z-index: 2000000000;
            border-radius: 10px;
            opacity: 0.8;
        }

        #CheckAlertxml {
            display: none;
            background: #fdfeff;
            box-shadow: 0 0 10px rgba(0,0,0,0.4);
            box-sizing: border-box;
            color: #101010;
            left: 50%;
            min-width: 645px;
            max-width: 700px;
            padding: 1.875em;
            position: absolute;
            top: 7%;
            transform: translate(-50%, -50%);
            z-index: 2000000000;
            border-radius: 10px;
            opacity: 0.8;
        }

        #falogout:hover {
            color: #FC0303 !important;
            cursor: pointer;
        }

        .fixed-div {
            position: fixed;
            overflow: hidden;
            width: 950px;
            height: 650px;
        }


        body.modal-open .container{
            -webkit-filter: blur(4px);
            -moz-filter: blur(4px);
            filter: blur(4px);
            filter: url("https://gist.githubusercontent.com/amitabhaghosh197/b7865b409e835b5a43b5/raw/1a255b551091924971e7dee8935fd38a7fdf7311/blur".svg#blur);
filter:progid:DXImageTransform.Microsoft.Blur(PixelRadius='4');
        }
 
