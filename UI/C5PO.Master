    <script type="text/javascript">
        window.Beacon('init', '24e48c05-b068-4f15-8892-fcc0880802b4');
        var cookies = document.cookie.split(';');
        var sUsername = "";
        var sUserrole = "";
        var sPersonname = "";
        var sEMailAddress = "";
        for (var l = 0; l < cookies.length; l++) {
            if (cookies[l].indexOf("CPersonName") > -1) {
                sPersonname = cookies[l].split("=")[1];
            }
            else if (cookies[l].indexOf("CEMailAddress") > -1) {
                sEMailAddress = cookies[l].split("=")[1];
            }
            else if (cookies[l].indexOf("CUserName") > -1) {
                sUsername = cookies[l].split("=")[1];
            }
            else if (cookies[l].indexOf("CUserRole") > -1) {
                sUserrole = cookies[l].split("=")[1];
            }

        }
        //alert(sUsername + " - " + sPersonname + " - " + sEMailAddress + " - " + sUserrole);

        window.Beacon('identify', {
            name: sUsername,
            login: sPersonname,
            email: sEMailAddress,
            usertype: sUserrole,
        });
        if (sEMailAddress == "") {
            window.Beacon('prefill', {text:'', subject: '', email: '' })
        }

</script>--%>

     <script id="ze-snippet" src="https://static.zdassets.com/ekr/snippet.js?key=115b8368-0fd6-4f41-bd95-8c6eddfd7ba7"> </script>
    <script type="text/javascript">
        window.zESettings = {
            webWidget: {
                launcher: {
                    label: {
                        'en-US': ' '
                    }
                }
            }
        };
    </script>
<script type="text/javascript">
    var cookies = document.cookie.split(';');
    //var sUsername = "";
    //var sUserrole = "";
    var sPersonname = "";
    var sEMailAddress = "";
    var bReadOnly = false;
    for (var l = 0; l < cookies.length; l++) {
        if (cookies[l].indexOf("CPersonName") > -1) {
            sPersonname = cookies[l].split("=")[1];
        }
        else if (cookies[l].indexOf("CEMailAddress") > -1) {
            sEMailAddress = cookies[l].split("=")[1];
            if (sEMailAddress != "")
                bReadOnly = true;
        }
        //else if (cookies[l].indexOf("CUserName") > -1) {
        //    sUsername = cookies[l].split("=")[1];
        //}
        //else if (cookies[l].indexOf("CUserRole") > -1) {
        //    sUserrole = cookies[l].split("=")[1];
        //}

    }
    zE('webWidget', 'prefill', {
        name: {
            value: sPersonname,
            readOnly: true // optional
        },
        email: {
            value: sEMailAddress,
            readOnly: bReadOnly // optional
        }
        //phone: {
        //    value: '61431909749',
        //    readOnly: true // optional
        //}
    });
</script>

    <form id="form1" runat="server">
        <script language="javascript" type="text/javascript">
            var ModalWndw = "<%=ModalWindow.ClientID %>";
        </script>
        <telerik:RadWindowManager ID="ModalWindowMngt" runat="server" EnableViewState="false">
            <Windows>
                <telerik:RadWindow ID="ModalWindow" runat="server" VisibleOnPageLoad="false" Height="625px"
                    IconUrl="Resources/16_16.ico" Width="1225px" EnableViewState="false" Modal="false"
                    VisibleStatusbar="False" ShowContentDuringLoad="false">
                </telerik:RadWindow>

                  <telerik:RadWindow ID="OrderManagement" runat="server" VisibleOnPageLoad="false" Height="625px"
                    IconUrl="Resources/16_16.ico" Width="1225px" EnableViewState="false" Modal="false"
                    VisibleStatusbar="False" ShowContentDuringLoad="false">
                </telerik:RadWindow>

                <telerik:RadWindow ID="RadWindow1" runat="server" VisibleOnPageLoad="false" Height="625px"
                    IconUrl="Resources/16_16.ico" Width="1225px" EnableViewState="false" Modal="false"
                    VisibleStatusbar="False" ShowContentDuringLoad="false">
                </telerik:RadWindow>
                <telerik:RadWindow ID="PFSHWindow" runat="server" VisibleOnPageLoad="false" Height="625px" CssClass="PFSHWindow"
                    IconUrl="Resources/16_16.ico" Width="1225px" EnableViewState="false" Modal="false"
                    VisibleStatusbar="False">
                </telerik:RadWindow>

            </Windows>
        </telerik:RadWindowManager>

        <div id="main" style="position: relative">
            <div id="divInternetLoader" style="display: none;">
                <div style="border: none; z-index: 100010; position: fixed; top: 0px; bottom: 0px; left: 0px; right: 0px; overflow: hidden; padding: 0; margin: 0; background-color: #000; opacity: 0.7;">
                    <div style="display:flex ; justify-content:center ; align-items:center ; height:100vh ">
                        <div style="margin:0; padding:0;font-family: sans-serif;color: #bfdbff;text-align: center;font-size: 150%;font-family: 'Helvetica Neue';">
                            <h1 style="font-weight: normal;margin: 0 auto; font-size: 100px; text-shadow: 0 2px 2px #000;">⚠</h1>
                            <h4 style="font-weight: normal; margin:0px 10px ; ">Internet connection lost. Please check your internet connection. You may need to retry your last action.</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <asp:Panel ID="pnlScroll" runat="server" Font-Size="Small" Font-Names="Microsoft Sans Serif"
                Width="100%" Style="position: static">


                <table bgcolor="#bfdbff" width="100%" cellpadding="0px" cellspacing="0px" id="mnuC5PO">
                    <tr style="margin: 0px; padding: 0px;" id="trmaintab">
                        <td width="90%" style="margin: 0px; padding: 0px; height: 35px">
                            <nav id="MainMenu" class="navstyle">
                                <ul>
                                    <li runat="server" id="mnuFile">
                                        <a href="#" id="ancFile">File</a>
                                        <div class="navhover">
                                            <ul>
                                                <li runat="server" id="mnuFile_smnuImport">
                                                    <a href="#">Import <span class="caret"></span></a>
                                                    <div>
                                                        <ul>
                                                           <%--<li runat="server" id="mnuFile_smnuLoadScannedDocuments"><a href="#" onclick="OpenModal('SCANNED DOCUMENTS');">Scanned Documents</a></li>--%>
                                                            <%--<li runat="server" id="mnuFile_smnuOnlineDocuments"><a href="#" onclick="OpenModal('UPLOAD SCANNED DOCUMENTS');">Upload Scanned Documents</a></li>--%>
                                                            <%--<li runat="server" id="mnuFile_smnuOnlineDocuments"><a href="#" onclick="OpenIndexing();">Upload Scanned Documents</a></li>--%>
                                                            <%--<li runat="server" id="mnuFile_smnuOnlineDocuments"><a href="#">Upload Documents</a>--%>
                                                           
                                                             <%-- remove temporary --%>
                                                            <%--<li runat="server" id="mnuFile_smnuTransactionalScan"><a href="#" onclick="OpenIndexing('Transactional Scanning');">Transactional Scanning</a></li>--%>
                                                            <li runat="server" id="mnuFile_smnuBulkScanning"><a href="#" onclick="OpenIndexing('Bulk Scanning and Fax');">Upload Scanned Documents</a></li> <%--Bulk Scanning & Fax--%>
                                                           <%-- </li>--%>
                                                        </ul>
                                                    </div>
                                                </li>
                                                <li runat="server" id="mnuFile_smnuLogout"><a href="#" onclick="OpenModal('Logout');" runat="server">Logout</a></li>
                                            </ul>
